{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "types": ["node"]
  },

  "include": [
    "src/**/*.ts",
    "src/types/**/*.d.ts"
  ],

  "exclude": [
    "tests",
    "dist",
    "node_modules"
  ]
}